# Private key de Vapi (Dashboard > API Keys > Private).
# Server-side: NUNCA usar prefijo NEXT_PUBLIC_ (expondría la llave al browser).
# Sin esta llave, el modulo de Llamadas del dashboard usa datos demo.
VAPI_PRIVATE_KEY=

# --- WhatsApp Cloud API (Meta) ---
# Verify token: lo inventas tú; debe coincidir con el del panel de Meta.
WHATSAPP_VERIFY_TOKEN=
# App Secret de la App de Meta (valida la firma X-Hub-Signature-256).
WHATSAPP_APP_SECRET=
# Para responder mensajes (no requeridos solo para recibir):
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- OAuth de Meta (conectar Facebook + Instagram de cada cliente) ---
# App "MiAgentIA" (tipo Negocios). El App ID no es secreto; el secret SÍ.
# Sin META_APP_SECRET el botón "Conectar" corre en modo demo (simulado).
META_APP_ID=1049131010901646
META_APP_SECRET=
# URL fija registrada en Meta. En dev se usa el origin local automáticamente.
META_REDIRECT_URI=https://conectar.miagentia.com/api/meta/callback
# Opcional: secreto propio para firmar el state (si no, usa META_APP_SECRET).
META_STATE_SECRET=
# Verify token del webhook de Messenger/Instagram (/api/webhooks/meta): lo
# inventas tú y debe coincidir con el que pegues en el panel de Meta
# (Webhooks > Verificar token).
META_WEBHOOK_VERIFY_TOKEN=

# --- Supabase (persistencia de mensajes de WhatsApp) ---
# Sin estas, los mensajes caen a un store en memoria (se pierden al reiniciar).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
